# Gemini API Key (from Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# GitHub Personal Access Token (needs repo scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=growthpigs
GITHUB_REPO=thinking-foundry

# Google Service Account JSON file path (for Drive integration)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT=./service-account.json

# Server port
PORT=3000
