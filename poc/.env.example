# Thinking Foundry — Environment Variables
# Copy to .env and fill in values

# Required — Voice sessions
GEMINI_API_KEY=your_gemini_api_key

# Required — Session persistence
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# Required — GitHub issue creation
GITHUB_TOKEN=github_pat_your_token
GITHUB_OWNER=growthpigs
GITHUB_REPO=thinking-foundry-vault

# Optional — User speech transcription
DEEPGRAM_API_KEY=your_deepgram_key

# Optional — Link auth admin
ADMIN_API_KEY=your_admin_key

# Optional — Google Drive auto-sync (creates session folders per user)
# Use B64 for Railway/cloud, file path for local dev
GOOGLE_SERVICE_ACCOUNT_B64=base64_encoded_service_account_json
GOOGLE_SERVICE_ACCOUNT=./path/to/service-account.json

# Optional — Email whitelist (comma-separated, deny-by-default if empty)
ALLOWED_EMAILS=you@example.com,client@company.com

# Optional — NotebookLM Crucible audio
NOTEBOOKLM_AUTH_B64=
